# Copy to .env and fill in. The .env file is gitignored.

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=replace-me-with-a-real-secret-for-any-non-dev-environment
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Each Company is reachable at <slug>.<TENANT_BASE_DOMAIN>; the bare base hosts super-admin.
# For local subdomain testing, `acme.localhost` resolves to 127.0.0.1 on modern Linux/macOS.
TENANT_BASE_DOMAIN=localhost

POSTGRES_DB=payroll
POSTGRES_USER=payroll
POSTGRES_PASSWORD=payroll
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Comma-separated Fernet keys, newest first. Generate with: make generate-key
# A non-empty value is required for any environment that runs encrypted-field code.
FIELD_ENCRYPTION_KEYS=

# Production-only (leave blank in dev)
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=False
